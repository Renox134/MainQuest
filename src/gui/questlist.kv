<QuestListItem>:
    size_hint_y: None
    height: 60
    padding: 10
    spacing: 10
    orientation: "horizontal"

    Label:
        text: root.name
        size_hint_x: 0.6
    ProgressBar:
        max: 1.0
        value: root.status
        size_hint_x: 0.4


<QuestListView>:
    viewclass: "QuestListItem"
    RecycleBoxLayout:
        default_size: None, dp(60)
        default_size_hint: 1, None
        size_hint_y: None
        height: self.minimum_height
        orientation: "vertical"


<QuestScreen>:
    orientation: "vertical"
    Label:
        text: "Quest List"
        size_hint_y: None
        height: 50
        bold: True
        font_size: "20sp"
    ScrollView:
        id: quest_list
