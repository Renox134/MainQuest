#:kivy 2.3.0

<GoalScreen>:
    name: "goal_screen"

    BoxLayout:
        id: layout
        orientation: "vertical"
        size_hint: 1, 1

        MDTopAppBar:
            id: top_app_bar
            type: "small"

            MDTopAppBarLeadingButtonContainer:
                MDActionTopAppBarButton:
                    icon: "chevron-left"
                    on_release: app.close_context_screen()

            MDTopAppBarTitle:
                id: goal_title
                pos_hint: {"center_x": .5, "center_y": .5}

        MDBoxLayout:
            orientation: "vertical"

            MDBoxLayout:
                id: plot_layout
                orientation: "vertical"

                MDSwiper:
                    id: swiper
                    items_spacing: dp(0)
                    width: root.width
                    size_hint_y: None
                    height: dp(300)

            MDDivider:
            MDBoxLayout:
                id: bar_chart_layout
