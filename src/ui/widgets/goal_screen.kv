#:kivy 2.3.0

<GoalScreen>:
    name: "goal_screen"

    BoxLayout:
        id: layout
        orientation: "vertical"
        size_hint: 1, 1

        MDTopAppBar:
            id: top_app_bar
            type: "small"

            MDTopAppBarLeadingButtonContainer:
                MDActionTopAppBarButton:
                    icon: "chevron-left"
                    on_release: app.close_goal_screen()

            MDTopAppBarTitle:
                id: goal_title
                pos_hint: {"center_x": .5, "center_y": .5}
        BoxLayout:
            id: plot_layout
            orientation: "vertical"
            # size_hint_y: 1

            MDSwiper:
                id: swiper
                items_spacing: dp(0)
                width: root.width
                height: dp(300)
                size_hint_y: None
                size_hint_x: None

        MDDivider:
        MDLabel:
            text: "Other"
            halign: "center"
