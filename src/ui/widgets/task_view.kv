#:kivy 2.3.0

<TaskView>:
    id: task_view
    size_hint_y: 0.5
    orientation: "vertical"

    MDBottomSheetDragHandle:

        # MDBottomSheetDragHandleTitle:
        #     text: "Task View"
        #     adaptive_height: True
        #     pos_hint: {"center_x": .0, "center_y": .5}

        # MDBottomSheetDragHandleButton:
        #     icon: "close"
        #     on_release: task_view.set_state("toggle")
        #     pos_hint: {"center_x": 1.0, "center_y": .5}

    MDBoxLayout:

        MDTextField:
            id: text_field
            pos_hint: {"center_x": .5, "center_y": .9}
            mode: "filled"
            text: task_view.task.description

            MDTextFieldHintText:
                text: "Task Description"
