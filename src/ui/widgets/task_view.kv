#:kivy 2.3.0

<TaskView>:
    id: task_view
    size_hint_y: 0.5
    orientation: "vertical"

    MDBottomSheetDragHandle:

    MDGridLayout:
        theme_bg_color: "Custom"
        md_bg_color: "#680606ff"
        cols: 1
        rows: 5
        orientation: "tb-lr"

        MDTextField:
            id: description_field
            mode: "filled"
            text: task_view.task.description
            padding: "12dp", "12dp"

            MDTextFieldHintText:
                text: "Task Description"

        MDTextField:
            id: notes_field
            mode: "filled"
            padding: "12dp", "12dp"

            MDTextFieldHintText:
                text: "Notes"

        MDGridLayout:
            rows: 1
            cols: 2
            padding: "12dp", "12dp", "12dp", "12dp"
            MDButton:
                style: "elevated"

                MDButtonIcon:
                    icon: "calendar"

                MDButtonText:
                    text: "Select Date"

            MDButton:
                style: "elevated"

                MDButtonIcon:
                    icon: "clock"

                MDButtonText:
                    text: "Select Time"
