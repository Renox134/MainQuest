#:kivy 2.3.0

<TaskScreen>:
    MDBoxLayout:
        id: task_layout_root
        orientation: "vertical"
        MDTopAppBar:
            id: top_app_bar
            type: "small"

            MDTopAppBarLeadingButtonContainer:
                MDActionTopAppBarButton:
                    icon: "chevron-left"
                    on_release: app.close_task_screen(root)
        MDGridLayout:
            rows: 5
            cols: 1

            MDTextField:
                id: description_field
                mode: "filled"
                on_focus: root.update_description()

                MDTextFieldHintText:
                    text: "Task Description"

            MDTextField:
                id: notes_field
                mode: "filled"
                on_focus: root.update_notes()

                MDTextFieldHintText:
                    text: "Notes"

            MDGridLayout:
                rows: 1
                cols: 1
                padding: "0dp", "6dp"
                size_hint_y: None
                height: "60dp"

                ScrollView:
                    do_scroll_x: True
                    do_scroll_y: False
                    adaptive_height: True
                    MDGridLayout:
                        rows: 1
                        cols: 5
                        adaptive_width: True
                        MDButton:
                            on_release: root.open_date_selector()

                            MDButtonText:
                                id: date_button_text
                                text: "Date"
                            MDButtonIcon:
                                icon: "calendar"
                        MDButton:
                            on_release: on_release: root.open_time_selector()

                            MDButtonText:
                                id: time_button_text
                                text: "Time"
                            MDButtonIcon:
                                icon: "clock"
                        MDButton:
                            on_release: root.select_time()

                            MDButtonText:
                                id: duration_button_text
                                text: "Duration"
                            MDButtonIcon:
                                icon: "timer-stop"
                        MDButton:
                            on_release: root.set_deadline()

                            MDButtonText:
                                text: "Deadline"
                            MDButtonIcon:
                                icon: "target"
                        MDButton:
                            on_release: root.assign_priority()

                            MDButtonText:
                                text: "Priority"
                            MDButtonIcon:
                                icon: "flag"
            MDGridLayout:
                rows: 1
                cols: 1

                ScrollView:
                    do_scroll_x: False
                    do_scroll_y: True

                    MDGridLayout:
                        rows: 1
                        cols: 1
                        adaptive_height: True
                        MDList:
                            id: subtask_list
