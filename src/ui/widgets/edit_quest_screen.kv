#:kivy 2.3.0

<EditQuestScreen>:
    name: "edit_quest_screen"

    BoxLayout:
        id: layout
        orientation: "vertical"
        size_hint: 1, 1

        MDTopAppBar:
            id: top_app_bar
            type: "small"

            MDTopAppBarLeadingButtonContainer:
                MDActionTopAppBarButton:
                    icon: "chevron-left"
                    on_release: root.save_and_close()

            MDTopAppBarTitle:
                id: quest_title
                pos_hint: {"center_x": .5, "center_y": .5}

            MDTopAppBarTrailingButtonContainer:
                MDActionTopAppBarButton:
                    id: context_button
                    icon: "dots-vertical"
                    on_release: root.on_more_pressed()


        MDGridLayout:
            cols: 1
            rows: 2

            MDTextField:
                id: name_field
                mode: "filled"
                input_type: "text"
                keyboard_suggestions: True

                MDTextFieldHintText:
                    text: "Name"

            MDBoxLayout:
                ScrollView:
                    MDBoxLayout:
                        id: goal_list_layout
                        orientation: "vertical"
                        adaptive_height: True
