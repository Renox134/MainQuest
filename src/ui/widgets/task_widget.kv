#:kivy 2.3.0

<ExpansionPanelTaskItem>:
    id: ExpansionPanelTaskItem
    MDExpansionPanelHeader:
        MDListItem:
            id: header
            ripple_effect: False
            on_release: app.tap_expansion_chevron(root, chevron)

            LeadingPressedIconButton:
                icon: "checkbox-blank-circle"
                on_release: root.complete_quest()

            MDListItemHeadlineText:
                id: name_text_field
                halign: "left"
                text: root.task.description

            TrailingPressedIconButton:
                id: chevron
                icon: "chevron-right"
                on_release: app.tap_expansion_chevron(root, chevron)

    MDExpansionPanelContent:
        id: subtask_container
        orientation: "vertical"

        MDList:
            id: subtask_list