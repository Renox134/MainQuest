#:kivy 2.3.0

MDScreen:
    id: global_root
    MDNavigationLayout:
        id: global_nav_layout
        MDScreenManager:
            id: outer_screen_manager
            MDScreen:
                name: "main_app_screen"
                BoxLayout:
                    orientation: "vertical"
                    MDTopAppBar:
                        id: top_app_bar
                        type: "small"

                        MDTopAppBarLeadingButtonContainer:
                            MDActionTopAppBarButton:
                                icon: "menu"
                                on_release: app.on_menu_pressed()

                        MDTopAppBarTitle:
                            id: app_title
                            text: "Main Quest"
                            pos_hint: {"center_x": .5, "center_y": .5}

                        MDTopAppBarTrailingButtonContainer:
                            MDActionTopAppBarButton:
                                icon: "dots-vertical"
                                on_release: app.on_more_pressed()

                    MDScreenManager:
                        id: screen_manager
                        MainAppWindow:
                            ScrollView:    
                                MDGridLayout:
                                    id: quest_layout
                                    cols: 1
                                    size_hint_y: None
                                    height: self.minimum_height
                        ProgressWindow:
                        CalendarWindow:

                    MDNavigationBar:
                        id: nav_bar
                        on_switch_tabs: app.on_nav_switch(*args)

                        BaseMDNavigationItem:
                            icon: "trophy"
                            text: "Progress"
                            on_release: app.on_trophy_pressed()

                        BaseMDNavigationItem:
                            icon: "book"
                            text: "Journal"
                            active: True
                            on_release: app.on_home_pressed()

                        BaseMDNavigationItem:
                            icon: "calendar"
                            text: "Calendar"
                            on_release: app.on_calendar_pressed()

        MDBottomSheet:
            id: bottom_sheet
            size_hint_x: 0.9
            size_hint_y: 0.5
            orientation: "vertical"

            MDBottomSheetDragHandle:
                id: drag_handle
                MDBottomSheetDragHandleTitle:
                    id: sheet_title
                    text: "Add Task"

                MDBottomSheetDragHandleButton:
                    icon: "check"
                    on_release: app.on_more_pressed()

            MDGridLayout:
                id: bottom_sheet_container
                rows: 1
                cols: 1

                MDTextField:
                    id: description_field
                    mode: "filled"
                    on_focus: app.on_more_pressed()

                    MDTextFieldHintText:
                        id: description_field_text
                        text: "Task Description"