#:kivy 2.3.0

MDScreen:
    id: global_root
    MDNavigationLayout:
        id: global_nav_layout
        MDScreenManager:
            id: outer_screen_manager
            MDScreen:
                name: "main_app_screen"
                BoxLayout:
                    orientation: "vertical"
                    MDTopAppBar:
                        id: top_app_bar
                        type: "small"

                        MDTopAppBarLeadingButtonContainer:
                            MDActionTopAppBarButton:
                                icon: "menu"
                                on_release: app.on_menu_pressed()

                        MDTopAppBarTitle:
                            id: app_title
                            text: "Main Quest"
                            pos_hint: {"center_x": .5, "center_y": .5}

                        MDTopAppBarTrailingButtonContainer:
                            MDActionTopAppBarButton:
                                id: top_app_barcontext_button
                                icon: "dots-vertical"
                                on_release: app.on_more_pressed()

                    MDScreenManager:
                        id: screen_manager
                        MainAppWindow:
                            ScrollView:    
                                MDGridLayout:
                                    id: quest_layout
                                    cols: 1
                                    size_hint_y: None
                                    height: self.minimum_height
                        CalendarWindow:

                    MDNavigationBar:
                        id: nav_bar
                        on_switch_tabs: app.on_nav_switch(*args)

                        BaseMDNavigationItem:
                            icon: "trophy"
                            text: "Progress"
                            on_release: app.on_trophy_pressed()

                        BaseMDNavigationItem:
                            icon: "book"
                            text: "Journal"
                            active: True
                            on_release: app.on_home_pressed()

                        BaseMDNavigationItem:
                            icon: "calendar"
                            text: "Calendar"
                            on_release: app.on_calendar_pressed()

        MDNavigationDrawer:
            id: nav_drawer
            drawer_type: "modal"
            radius: 0, dp(16), dp(16), 0

            MDNavigationDrawerMenu:

                MDNavigationDrawerLabel:
                    text: "Settings"
                    halign: "center"

                MDNavigationDrawerDivider:

                MDNavigationDrawerItem:

                    MDNavigationDrawerItemLeadingIcon:
                        icon: "palette"

                    MDNavigationDrawerItemText:
                        text: "Styling Options"

                MDNavigationDrawerItem:
                    on_release: app.select_main_color_theme()

                    MDNavigationDrawerItemText:
                        id: main_color_theme_text

                    MDIconButton:
                        icon: "square"
                        on_release: app.select_main_color_theme()

                MDNavigationDrawerItem:

                    MDNavigationDrawerItemText:
                        id: theme_style_text

                    MDSwitch:
                        id: theme_style_switch
                        icon_active: "lightbulb-on"
                        icon_active_color: "white"
                        icon_inactive: "lightbulb"
                        icon_inactive_color: "grey"
                        on_active: app.update_app_lighting_theme()

                MDNavigationDrawerDivider:
