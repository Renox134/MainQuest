#:kivy 2.3.0

<BaseMDNavigationItem>:
    MDNavigationItemIcon:
        icon: root.icon

    MDNavigationItemLabel:
        text: root.text

<MainAppWindow>:
    name: "main_window"

<ProgressWindow>:
    name: "progress_window"
    MDLabel:
        text: "Progress tracking is comming soon :)"
        halign: "center"

<CalendarWindow>:
    name: "calendar_window"
    MDLabel:
        text: "Calendar is comming soon :)"
        halign: "center"

<TaskView>:
    rows: 5
    cols: 1

    MDTextField:
        id: description_field
        mode: "filled"

        MDTextFieldHintText:
            text: "Task Description"

    MDTextField:
        id: notes_field
        mode: "filled"

        MDTextFieldHintText:
            text: "Notes"

    MDGridLayout:
        rows: 1
        cols: 1
        padding: "0dp", "12dp"

        ScrollView:
            do_scroll_x: True
            do_scroll_y: False
            adaptive_height: True
            MDGridLayout:
                rows: 1
                cols: 5
                adaptive_width: True
                theme_bg_color: "Custom"
                md_bg_color: "00ff00"
                MDButton:
                    on_release: root.select_date()

                    MDButtonText:
                        text: "Date"
                    MDButtonIcon:
                        icon: "calendar"
                MDButton:
                    on_release: root.select_time()

                    MDButtonText:
                        text: "Time"
                    MDButtonIcon:
                        icon: "clock"
                MDButton:
                    on_release: root.select_time()

                    MDButtonText:
                        text: "Duration"
                    MDButtonIcon:
                        icon: "timer-stop"
                MDButton:
                    on_release: root.set_deadline()

                    MDButtonText:
                        text: "Deadline"
                    MDButtonIcon:
                        icon: "target"
                MDButton:
                    on_release: root.assign_priority()

                    MDButtonText:
                        text: "Priority"
                    MDButtonIcon:
                        icon: "flag"
    MDGridLayout:
        rows: 1
        cols: 1
        padding: "0dp", "12dp"

        ScrollView:
            do_scroll_x: False
            do_scroll_y: True

            MDGridLayout:
                rows: 1
                cols: 1
                adaptive_height: True
                MDList:
                    MDListItem:
                        MDListItemHeadlineText:
                            text: "Headline"
                        MDListItemSupportingText:
                            text: "Supporting text"
                    MDListItem:
                        MDListItemHeadlineText:
                            text: "Headline"
                        MDListItemSupportingText:
                            text: "Supporting text"

<DateSelectorField>:
    id: date_field
    mode: "filled"
    pos_hint: {'center_x': .5, 'center_y': .85}
    size_hint_x: .5

    MDTextFieldHintText:
        text: "Date picker"

    MDTextFieldHelperText:
        text: "DD/MM/YYYY"
        mode: "persistent"

    MDTextFieldTrailingIcon:
        icon: "calendar"
