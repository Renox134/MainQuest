#:kivy 2.3.0

<BaseMDNavigationItem>:
    MDNavigationItemIcon:
        icon: root.icon

    MDNavigationItemLabel:
        text: root.text

<MainAppWindow>:
    name: "main_window"

<ProgressWindow>:
    name: "progress_window"
    MDLabel:
        text: "Progress tracking is comming soon :)"
        halign: "center"

<CalendarWindow>:
    name: "calendar_window"
    MDLabel:
        text: "Calendar is comming soon :)"
        halign: "center"

<TaskView>:
    rows: 3
    cols: 1

    MDTextField:
        id: description_field
        mode: "filled"

        MDTextFieldHintText:
            text: "Task Description"

    MDTextField:
        id: notes_field
        mode: "filled"

        MDTextFieldHintText:
            text: "Notes"

    MDGridLayout:
        rows: 1
        cols: 1
        padding: "0dp", "12dp"

        ScrollView:
            do_scroll_x: True
            do_scroll_y: False
            MDGridLayout:
                rows: 1
                cols: 5
                adaptive_width: True
                MDButton:
                    MDButtonText:
                        text: "Date"
                    MDButtonIcon:
                        icon: "calendar"
                MDButton:
                    MDButtonText:
                        text: "Time"
                    MDButtonIcon:
                        icon: "clock"
                MDButton:
                    MDButtonText:
                        text: "Deadline"
                    MDButtonIcon:
                        icon: "target"
                MDButton:
                    MDButtonText:
                        text: "Date"
                    MDButtonIcon:
                        icon: "calendar"
                MDButton:
                    MDButtonText:
                        text: "Date"
                    MDButtonIcon:
                        icon: "calendar"

<DateSelectorField>:
    id: date_field
    mode: "filled"
    pos_hint: {'center_x': .5, 'center_y': .85}
    size_hint_x: .5

    MDTextFieldHintText:
        text: "Date picker"

    MDTextFieldHelperText:
        text: "DD/MM/YYYY"
        mode: "persistent"

    MDTextFieldTrailingIcon:
        icon: "calendar"

<TaskBottomSheet>:
    id: task_bottom_sheet
    size_hint_y: 0.7
    size_hint_x: 0.95
    orientation: "vertical"

    MDBottomSheetDragHandle:

    MDGridLayout:
        theme_bg_color: "Custom"
        md_bg_color: "#680606ff"
        cols: 1
        rows: 5
        orientation: "tb-lr"

        TaskView:

        # DateSelectorField:
        #     on_focus: task_bottom_sheet.show_date_picker(self.focus)
