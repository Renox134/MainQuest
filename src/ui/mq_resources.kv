#:kivy 2.3.0

<BaseMDNavigationItem>:
    MDNavigationItemIcon:
        icon: root.icon

    MDNavigationItemLabel:
        text: root.text

<MainAppWindow>:
    name: "main_window"

<ProgressWindow>:
    name: "progress_window"

    ScrollView:
        MDList:
            id: goal_list

<CalendarWindow>:
    name: "calendar_window"
    MDLabel:
        text: "Calendar is comming soon :)"
        halign: "center"

<ListTaskItem>:
    id: header
    ripple_effect: False
    on_release: app.open_task_screen(self.task, self.parent_quest, self.parent_task)

    LeadingPressedIconButton:
        id: confirm_icon
        icon: "checkbox-blank-circle"
        on_release: root.complete_task()

    MDListItemHeadlineText:
        id: name_text_field
        halign: "left"
        text: root.task.description

<ListGoalItem>:
    id: base_item
    ripple_effect: False
    on_release: app.open_goal_screen(self.goal)

    MDListItemHeadlineText:
        id: name_text_field
        halign: "left"
        text: root.goal.name

    MDListItemTrailingIcon:
        icon: "trophy"

    MDIconButton:
        id: context_button
        icon: "dots-vertical"
        on_release: root.open_goal_context()

<GoalScreen>:
    name: "goal_screen"

    BoxLayout:
        id: layout
        orientation: "vertical"
        MDTopAppBar:
            id: top_app_bar
            type: "small"

            MDTopAppBarLeadingButtonContainer:
                MDActionTopAppBarButton:
                    icon: "chevron-left"
                    on_release: app.close_goal_screen()

            MDTopAppBarTitle:
                id: goal_title
                pos_hint: {"center_x": .5, "center_y": .5}
        BoxLayout:
            id: plot_layout