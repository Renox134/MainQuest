#:kivy 2.3.0

<BaseMDNavigationItem>:
    MDNavigationItemIcon:
        icon: root.icon

    MDNavigationItemLabel:
        text: root.text

<MainAppWindow>:
    name: "main_window"

<ProgressScreen>:
    name: "progress_screen"

    ScrollView:
        MDBoxLayout:
            orientation: "vertical"
            adaptive_height: True
            MDList:
                id: goal_list
            # MDDivider:
            MDList:
                id: milestone_list

<CalendarWindow>:
    name: "calendar_window"
    MDLabel:
        text: "Calendar is comming soon :)"
        halign: "center"

<ListTaskItem>:
    id: header
    ripple_effect: False
    on_release: app.open_task_screen(self.task, self.parent_quest, self.parent_task)

    LeadingPressedIconButton:
        id: confirm_icon
        icon: "checkbox-blank-circle"
        on_release: root.complete_task()

    MDListItemHeadlineText:
        id: name_text_field
        halign: "left"
        text: root.task.description

<ListGoalItem>:
    id: base_item
    ripple_effect: False
    on_release: app.open_goal_screen(self.goal)

    MDListItemHeadlineText:
        id: name_text_field
        halign: "left"
        text: root.goal.name

    MDListItemTrailingIcon:
        icon: "trophy"

    MDIconButton:
        id: context_button
        icon: "dots-vertical"
        on_release: root.open_goal_context()

<ListMilestoneItem>:
    MDListItemHeadlineText:
        id: name_text_field
        halign: "left"
        text: root.milestone.name

    MDListItemSupportingText:
        id: supporting_text

    MDListItemTrailingIcon:
        icon: "trophy"
